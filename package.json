{
  "name": "wechat-offwork-stats",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.25.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "pnpm build:client && pnpm build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "lint": "biome check src server shared package.json biome.json commitlint.config.cjs ecosystem.config.cjs vite.config.ts tsconfig.json tsconfig.node.json tsconfig.server.json",
    "format": "biome check --write src server shared package.json biome.json commitlint.config.cjs ecosystem.config.cjs vite.config.ts tsconfig.json tsconfig.node.json tsconfig.server.json",
    "commitlint": "commitlint",
    "prepare": "husky",
    "start": "pnpm start:server",
    "start:server": "node dist-server/server/index.js"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,cjs,mjs,json,css}": [
      "biome check --write"
    ]
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.6.1",
    "mysql2": "^3.15.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.5",
    "recharts": "^3.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.7"
  }
}
